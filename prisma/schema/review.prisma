model Review {
  id         String   @id @default(uuid())
  userId     String
  medicineId String
  medicine   Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  rating     Rating?
  description String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reviews")
}