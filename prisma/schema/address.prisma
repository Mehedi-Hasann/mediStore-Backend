model Address {
  id       String @id @default(uuid())

  fullName String
  phone    String
  city     String
  area      String?
  street    String?
  houseNo   String?
  postalCode String?

  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  orders   Order[]

  @@map("address")
  @@unique([id, userId])
}